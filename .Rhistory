suppressPackageStartupMessages({
library(readxl)
library(dplyr)
library(tidyr)
library(stringr)
})
RAW_FILE  <- "src/data/raw/2024.26.10 - პარლამენტი.xlsx"
TOTAL_PR_SEATS <- 150L
THRESHOLD      <- 0.05
# ── Party mapping ─────────────────────────────────────────────────────────────
# Maps ballot number (leading digits in column name) → party_id in parties.yml.
# Every party on the ballot is mapped explicitly; nothing falls through to "other".
PARTY_MAP <- c(
"3"  = "unity_development",    # საქართველოს ერთობისა და განვითარების პარტია
"4"  = "coalition_for_change", # კოალიცია ცვლილებისთვის
"5"  = "unity",                # ერთიანობა-ნაციონალური მოძრაობა
"6"  = "european_democrats",   # ევროპელი დემოკრატები
"8"  = "patriots",             # საქართველოს პატრიოტთა ალიანსი
"9"  = "strong_georgia",       # ძლიერი საქართველო
"10" = "labour",               # საქართველოს ლეიბორისტული პარტია
"12" = "our_georgia",          # ჩვენი გაერთიანებული საქართველო
"16" = "change_georgia",       # შეცვალე საქართველო
"17" = "georgia_party",        # საქართველო
"20" = "free_georgia",         # თავისუფალი საქართველო
"21" = "tribuna",              # ტრიბუნა
"23" = "chven",                # ჩვენ
"25" = "gakharia",             # გახარია საქართველოსთვის
"26" = "left_alliance",        # მემარცხენე ალიანსი
"27" = "georgian_unity",       # ქართველ ერთობა
"36" = "girchi",               # გირჩი
"41" = "gd"                    # ქართული ოცნება
)
# ─────────────────────────────────────────────────────────────────────────────
# 1. READ RAW DATA
# ─────────────────────────────────────────────────────────────────────────────
cat("Reading:", RAW_FILE, "\n")
raw_names <- names(read_excel(RAW_FILE, n_max = 0))
raw_names
dir()
cd("../")
setwd("../")
dir
dir)
dir()
# ─────────────────────────────────────────────────────────────────────────────
# 1. READ RAW DATA
# ─────────────────────────────────────────────────────────────────────────────
cat("Reading:", RAW_FILE, "\n")
raw_names <- names(read_excel(RAW_FILE, n_max = 0))
# Extract ballot numbers from the Georgian party column names (columns 11–28)
ballot_nums <- str_extract(raw_names[11:28], "^\\d+")
ballot_nums
col_names <- c(
"district_num", "district_name",
"precinct_num", "precinct_status",
"registered_main", "ballots_received",
"registered_special",
"voted_noon", "voted_5pm", "voted_total",
paste0("p_", ballot_nums),   # party vote columns
"invalid_ballots"
)
raw <- read_excel(RAW_FILE, col_names = col_names, skip = 1) %>%
mutate(
district_num = as.integer(district_num),
across(starts_with("p_") | c(registered_main, registered_special,
voted_noon, voted_5pm, voted_total,
invalid_ballots, ballots_received),
~ suppressWarnings(as.numeric(.x)))
) %>%
filter(!is.na(district_num))   # drop any blank/summary rows
long <- raw %>%
pivot_longer(
cols      = all_of(party_cols),
names_to  = "col_name",
values_to = "votes"
) %>%
mutate(
ballot_num = str_extract(col_name, "\\d+"),
party_id   = coalesce(PARTY_MAP[ballot_num], "other"),
votes      = replace_na(votes, 0L),
registered = registered_main + registered_special
)
long
raw
# ─────────────────────────────────────────────────────────────────────────────
# 2. RESHAPE TO LONG FORMAT & MAP PARTIES
# ─────────────────────────────────────────────────────────────────────────────
party_cols <- paste0("p_", ballot_nums)
long <- raw %>%
pivot_longer(
cols      = all_of(party_cols),
names_to  = "col_name",
values_to = "votes"
)
long
long <- raw %>%
pivot_longer(
cols      = all_of(party_cols),
names_to  = "col_name",
values_to = "votes"
) %>%
mutate(
ballot_num = str_extract(col_name, "\\d+"),
party_id   = coalesce(PARTY_MAP[ballot_num], "other"),
votes      = replace_na(votes, 0L),
registered = registered_main + registered_special
)
# Warn about unmapped districts
unmapped <- long %>%
filter(is.na(region_id)) %>%
distinct(district_num, district_name)
if (nrow(unmapped) > 0) {
message("WARNING — unmapped districts (excluded from output):")
print(unmapped)
long <- filter(long, !is.na(region_id))
}
# ─────────────────────────────────────────────────────────────────────────────
# 3. NATIONAL TOTALS, THRESHOLD & SEAT ALLOCATION
# ─────────────────────────────────────────────────────────────────────────────
national_by_party <- long %>%
group_by(party_id) %>%
summarise(votes = sum(votes), .groups = "drop") %>%
mutate(
total_votes       = sum(votes),
vote_share        = votes / total_votes,
threshold_status  = if_else(party_id != "other" & vote_share >= THRESHOLD,
"passed", "failed")
)
national_by_party
# Seat allocation: only parties that passed the threshold
votes_above <- national_by_party %>%
filter(threshold_status == "passed") %>%
{ setNames(.$votes, .$party_id) }
seats_df <- dhondt(votes_above, TOTAL_PR_SEATS) %>%
bind_rows(
national_by_party %>%
filter(threshold_status != "passed") %>%
transmute(party_id, seats_pr = 0L)
)
